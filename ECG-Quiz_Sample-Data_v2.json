              "question_stem": "What is the definition of wide complex tachycardia?",
              "question_format": "identify_features",
              "answer": {
                "summary": "WCT = QRS >120ms + rate >100/min",
                "ecg_findings": [
                  {
                    "category": "Definition",
                    "findings": [
                      "QRS complex must be wide: >120ms (>3 small squares)",
                      "Patient must be tachycardic: >100/min"
                    ]
                  },
                  {
                    "category": "Differential diagnosis of WCT",
                    "findings": [
                      "Ventricular tachycardia (VT)",
                      "Supraventricular tachycardia (SVT) with aberrancy",
                      "Pacemaker rhythms"
                    ]
                  }
                ]
              }
            },
            {
              "question_id": "LITFL-EX-0013-A-Q2",
              "sequence": 2,
              "question_stem": "What clinical features help differentiate VT from SVT?",
              "question_format": "differential_diagnosis",
              "answer": {
                "summary": "History, exam findings, and ECG features all contribute — VT is more common overall (80%, up to 95% in IHD)",
                "ecg_findings": [
                  {
                    "category": "History favouring VT",
                    "findings": [
                      "No prior history of tachycardia",
                      "History of structural cardiac disease",
                      "Known pacemaker or ICD"
                    ]
                  },
                  {
                    "category": "Examination favouring VT",
                    "findings": [
                      "Unstable patient",
                      "Cardiac failure",
                      "Midline sternotomy scar",
                      "Cannon a-waves",
                      "Heart sound fluctuations (especially S1)"
                    ]
                  },
                  {
                    "category": "ECG features favouring VT",
                    "findings": [
                      "Extreme right axis",
                      "Minor rate variation",
                      "Chest lead concordance"
                    ]
                  },
                  {
                    "category": "ECG features favouring SVT",
                    "findings": [
                      "Rate exactly 150/min",
                      "Narrower QRS width (120-140ms)"
                    ]
                  }
                ]
              }
            },
            {
              "question_id": "LITFL-EX-0013-A-Q3",
              "sequence": 3,
              "question_stem": "Which algorithms can help differentiate SVT/aberrant conduction from VT?",
