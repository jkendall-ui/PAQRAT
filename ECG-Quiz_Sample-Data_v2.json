              "related_media_ids": ["LITFL-EX-0013-IMG-01", "LITFL-EX-0013-IMG-02"],
              "answer": {
                "summary": "Brugada criteria and Vereckei criteria — both ~90% accurate, both use a simple 4-step process",
                "ecg_findings": [
                  {
                    "category": "Brugada Criteria performance",
                    "findings": [
                      "Sensitivity: 98.7%",
                      "Specificity: 96.5%",
                      "Test accuracy: 90% (self-reported)"
                    ]
                  },
                  {
                    "category": "Vereckei Criteria performance",
                    "findings": [
                      "Sensitivity: 95.7%",
                      "Specificity: 73.4%",
                      "Test accuracy: 90% (self-reported)"
                    ]
                  }
                ],
                "interpretation_text": "Both criteria involve a simple four-step process. However, both get it wrong about 10% of the time. In the unstable patient, the distinction between SVT and VT is academic — they need urgent action (DC shock or a fast-acting antiarrhythmic)."
